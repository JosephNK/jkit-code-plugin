  "repository": {
    "type": "git",
    "url": "https://github.com/JosephNK/jkit-code-plugin.git"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.3",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "eslint-import-resolver-typescript": "^3.6.3 || ^4.0.0",
    "eslint-plugin-import": "^2.31.0"
  }
