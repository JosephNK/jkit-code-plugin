import { defineConfig, globalIgnores } from 'eslint/config';
import nextVitals from 'eslint-config-next/core-web-vitals';
import nextTs from 'eslint-config-next/typescript';
import prettier from 'eslint-config-prettier';
import boundaries from 'eslint-plugin-boundaries';
import simpleImportSort from 'eslint-plugin-simple-import-sort';
import sonarjs from 'eslint-plugin-sonarjs';
import unusedImports from 'eslint-plugin-unused-imports';
import tseslint from 'typescript-eslint';

// Shared restricted patterns (applied globally)
const baseRestrictedPatterns = [
  {
    group: ['../../**'],
    message: 'Use @/* path alias instead of deep relative parent imports.',
  },
  {
    group: ['tailwindcss', 'tailwindcss/**', 'unocss', 'unocss/**', 'windicss', 'windicss/**'],
    message: 'Utility CSS frameworks are not allowed. Use Mantine style props.',
  },
  {
    group: ['@emotion/*', 'styled-components', 'styled-jsx', 'styled-jsx/**'],
    message: 'CSS-in-JS libraries are not allowed. Use Mantine style props or CSS Modules.',
  },
];

// External packages banned from domain layer (pure TS only)
const frameworkPackages = [
  'react',
  'react/**',
  'react-dom',
  'react-dom/**',
  'next',
  'next/**',
  'next-auth',
  'next-auth/**',
  'mongodb',
  'mongodb/**',
  '@mantine/**',
  '@tanstack/**',
];

const eslintConfig = defineConfig([
  ...nextVitals,
  ...nextTs,

  // Type-checked linting (enables rules that require type information)
  ...tseslint.configs.recommendedTypeCheckedOnly.map((config) => ({
    ...config,
    files: ['**/*.{ts,tsx}'],
  })),
  {
    files: ['**/*.{ts,tsx}'],
    languageOptions: {
      parserOptions: {
        projectService: true,
        tsconfigRootDir: import.meta.dirname,
      },
    },
    rules: {
      // Disable rules from recommendedTypeCheckedOnly that conflict or are too noisy
      '@typescript-eslint/no-unsafe-assignment': 'off',
      '@typescript-eslint/no-unsafe-member-access': 'off',
      '@typescript-eslint/no-unsafe-call': 'off',
      '@typescript-eslint/no-unsafe-return': 'off',
      '@typescript-eslint/no-unsafe-argument': 'off',
      '@typescript-eslint/no-misused-promises': 'off',
      '@typescript-eslint/no-floating-promises': 'off',
      '@typescript-eslint/require-await': 'off',
      '@typescript-eslint/restrict-template-expressions': 'off',
      '@typescript-eslint/no-redundant-type-constituents': 'off',
      '@typescript-eslint/no-base-to-string': 'off',
      '@typescript-eslint/unbound-method': 'off',
      // Warn on deprecated APIs (e.g. React.FormEvent)
      '@typescript-eslint/no-deprecated': 'error',
    },
  },

  // Prettier — disable conflicting formatting rules
  prettier,

  // SonarJS — code quality (cognitive complexity, duplicate branches, etc.)
  sonarjs.configs.recommended,
  {
    rules: {
      'sonarjs/todo-tag': 'off',
      'sonarjs/no-nested-conditional': 'warn',
    },
  },

  // Import sorting & unused imports
  {
    plugins: {
      'simple-import-sort': simpleImportSort,
      'unused-imports': unusedImports,
    },
    rules: {
      'simple-import-sort/imports': 'error',
      'simple-import-sort/exports': 'error',
      'unused-imports/no-unused-imports': 'error',
      'unused-imports/no-unused-vars': [
        'warn',
        { vars: 'all', varsIgnorePattern: '^_', args: 'after-used', argsIgnorePattern: '^_' },
      ],
    },
  },

  // Custom rules
  {
    rules: {
      'no-console': ['warn', { allow: ['warn', 'error'] }],
      'prefer-const': 'error',
      '@typescript-eslint/no-unused-vars': 'off', // handled by unused-imports
      // Enforce type-only imports for type-only usage
      '@typescript-eslint/consistent-type-imports': [
        'error',
        { prefer: 'type-imports', fixStyle: 'inline-type-imports' },
      ],
      // Warn on explicit any — prefer proper typing
      '@typescript-eslint/no-explicit-any': 'warn',
      // Path alias enforcement, utility CSS ban & CSS-in-JS ban
      'no-restricted-imports': [
        'error',
        {
          patterns: baseRestrictedPatterns,
        },
      ],
      // Functional components only (no class components)
      'react/function-component-definition': [
        'error',
        {
          namedComponents: ['function-declaration', 'arrow-function'],
          unnamedComponents: 'arrow-function',
        },
      ],
      // Ban React.FC / React.FunctionComponent — use explicit props typing
      // Ban component="a" — use next/link Link for internal navigation
      'no-restricted-syntax': [
        'warn',
        {
          selector:
            "TSTypeReference[typeName.object.name='React'][typeName.property.name='FC']",
          message: 'Use explicit props typing instead of React.FC.',
        },
        {
          selector:
            "TSTypeReference[typeName.object.name='React'][typeName.property.name='FunctionComponent']",
          message: 'Use explicit props typing instead of React.FunctionComponent.',
        },
        {
          selector: "JSXAttribute[name.name='component'][value.value='a']",
          message:
            'Do not use component="a" for internal links — it causes full page reload. Use component={Link} from next/link instead.',
        },
      ],
    },
  },

  // Domain layer — pure TS only (no framework dependencies, no browser/runtime globals)
  {
    files: ['src/lib/domain/**/*.ts'],
    rules: {
      'no-restricted-imports': [
        'error',
        {
          patterns: [
            ...baseRestrictedPatterns,
            {
              group: frameworkPackages,
              message: 'Domain layer must be pure TypeScript. No framework dependencies allowed.',
            },
          ],
        },
      ],
      'no-restricted-globals': [
        'error',
        { name: 'fetch', message: 'Domain layer must be pure. Use Repository ports for data access.' },
        { name: 'window', message: 'Domain layer must not access browser globals.' },
        { name: 'document', message: 'Domain layer must not access browser globals.' },
        { name: 'localStorage', message: 'Domain layer must not access browser globals.' },
        { name: 'sessionStorage', message: 'Domain layer must not access browser globals.' },
      ],
    },
  },

  // Page (Server Component) — no Hook calls (async/await only, data loading + i18n)
  // Excludes _components/ and _providers/ which are Client Components
  {
    files: ['src/app/**/*.{ts,tsx}'],
    ignores: ['src/app/**/_components/**', 'src/app/**/_providers/**'],
    rules: {
      'no-restricted-syntax': [
        'error',
        {
          selector: 'CallExpression[callee.name=/^use[A-Z]/]',
          message:
            'Page/layout files are Server Components and must not call Hooks. Move Hook calls to _components/.',
        },
        {
          selector: 'CallExpression[callee.property.name=/^use[A-Z]/]',
          message:
            'Page/layout files are Server Components and must not call Hooks. Move Hook calls to _components/.',
        },
      ],
    },
  },

  // Architecture boundaries
  {
    plugins: {
      boundaries,
    },
    settings: {
      'boundaries/elements': [
        // Domain layer — pure TS only (folder mode: auto-appends /**/* to pattern)
        { type: 'domain-model', pattern: ['src/lib/domain/models'] },
        { type: 'domain-error', pattern: ['src/lib/domain/errors'] },
        { type: 'domain-port', pattern: ['src/lib/domain/ports'] },
        { type: 'domain-service', pattern: ['src/lib/domain/services'] },
        // API adapter layer
        { type: 'api-client', mode: 'full', pattern: ['src/lib/api/client.ts'] },
        { type: 'api-endpoint', mode: 'full', pattern: ['src/lib/api/endpoints.ts'] },
        { type: 'api-dto', mode: 'full', pattern: ['src/lib/api/types.ts'] },
        { type: 'api-mapper', pattern: ['src/lib/api/mappers'] },
        { type: 'api-repository', pattern: ['src/lib/api/repositories'] },
        { type: 'api-hook', pattern: ['src/lib/api/hooks'] },
        // API helper (catch-all for lib/api/*.ts — response, services, get-current-user, etc.)
        { type: 'api-helper', mode: 'full', pattern: ['src/lib/api/*.ts'] },
        // Email templates — pure TS (HTML string builders)
        { type: 'email-template', pattern: ['src/lib/email-templates'] },
        // DB layer
        { type: 'db', pattern: ['src/lib/db'] },
        // Shared lib (query-client, etc.)
        { type: 'lib-shared', mode: 'full', pattern: ['src/lib/*.ts'] },
        // Auth configuration
        { type: 'auth', mode: 'full', pattern: ['src/auth.ts'] },
        // UI layer — shared components
        { type: 'shared-ui', pattern: ['src/components'] },
        // Page-colocated Client Components and Providers
        { type: 'page-component', pattern: ['src/app/**/_components'] },
        { type: 'page-provider', pattern: ['src/app/**/_providers'] },
        // Common (shared across app)
        { type: 'dictionary', mode: 'full', pattern: ['src/common/dictionaries/*', 'src/app/*/dictionaries.ts'] },
        { type: 'shared-type', pattern: ['src/common/types'] },
        // Page (catch-all for app/)
        { type: 'page', pattern: ['src/app'] },
      ],
      'boundaries/ignore': [
        '**/*.test.ts',
        '**/*.test.tsx',
        '**/*.spec.ts',
        '**/*.spec.tsx',
        '*.config.*',
        '*.ts',
        '*.d.ts',
        'types/**',
        'src/theme.ts',
        'src/common/types/**',
        'src/proxy.ts',
      ],
    },
    rules: {
      'boundaries/no-unknown': 'error',
      'boundaries/no-unknown-files': 'error',
      'boundaries/dependencies': [
        'error',
        {
          default: 'disallow',
          rules: [
            // Domain Model — pure TS only
            { from: { type: 'domain-model' }, allow: [{ to: { type: 'domain-model' } }] },
            // Domain Error — pure TS only
            { from: { type: 'domain-error' }, allow: [{ to: { type: 'domain-error' } }] },
            // Domain Port — domain/models only
            { from: { type: 'domain-port' }, allow: [{ to: { type: 'domain-model' } }] },
            // Domain Service — domain/models, domain/ports, domain/errors, other domain/services (shared helpers)
            {
              from: { type: 'domain-service' },
              allow: [
                { to: { type: 'domain-model' } },
                { to: { type: 'domain-port' } },
                { to: { type: 'domain-error' } },
                { to: { type: 'domain-service' } },
              ],
            },
            // API Client — pure TS only
            { from: { type: 'api-client' }, allow: [] },
            // API Endpoint — pure TS only
            { from: { type: 'api-endpoint' }, allow: [] },
            // API DTO — pure TS only
            { from: { type: 'api-dto' }, allow: [] },
            // Mapper — domain/models, api/types
            {
              from: { type: 'api-mapper' },
              allow: [{ to: { type: 'domain-model' } }, { to: { type: 'api-dto' } }],
            },
            // Repository — api/client, api/endpoints, api/mappers, domain/ports, domain/errors, db
            {
              from: { type: 'api-repository' },
              allow: [
                { to: { type: 'api-client' } },
                { to: { type: 'api-endpoint' } },
                { to: { type: 'api-mapper' } },
                { to: { type: 'domain-port' } },
                { to: { type: 'domain-error' } },
                { to: { type: 'domain-model' } },
                { to: { type: 'db' } },
              ],
            },
            // Hook — domain/services, TanStack Query only
            { from: { type: 'api-hook' }, allow: [{ to: { type: 'domain-service' } }] },
            // API Helper — domain/*, api/repositories, other api-helpers, auth
            {
              from: { type: 'api-helper' },
              allow: [
                { to: { type: 'domain-model' } },
                { to: { type: 'domain-error' } },
                { to: { type: 'domain-port' } },
                { to: { type: 'domain-service' } },
                { to: { type: 'api-repository' } },
                { to: { type: 'api-helper' } },
                { to: { type: 'email-template' } },
                { to: { type: 'auth' } },
              ],
            },
            // Email Template — may access dictionaries for i18n
            {
              from: { type: 'email-template' },
              allow: [{ to: { type: 'dictionary' } }, { to: { type: 'shared-type' } }],
            },
            // DB — pure TS + mongodb driver only (no element imports)
            { from: { type: 'db' }, allow: [] },
            // Shared lib — pure TS (query-client, etc.)
            { from: { type: 'lib-shared' }, allow: [] },
            // Auth — NextAuth config (dynamic import for services)
            { from: { type: 'auth' }, allow: [{ to: { type: 'api-helper' } }] },
            // Shared UI — React, Mantine, domain/models, shared types
            {
              from: { type: 'shared-ui' },
              allow: [
                { to: { type: 'domain-model' } },
                { to: { type: 'shared-ui' } },
                { to: { type: 'shared-type' } },
              ],
            },
            // Page-colocated Client Components — Hooks, shared UI, domain/models, shared lib
            {
              from: { type: 'page-component' },
              allow: [
                { to: { type: 'api-hook' } },
                { to: { type: 'shared-ui' } },
                { to: { type: 'domain-model' } },
                { to: { type: 'page-component' } },
                { to: { type: 'lib-shared' } },
                { to: { type: 'shared-type' } },
              ],
            },
            // Page-colocated Providers — shared lib only
            {
              from: { type: 'page-provider' },
              allow: [
                { to: { type: 'lib-shared' } },
              ],
            },
            // Dictionary — shared types + other dictionary files
            {
              from: { type: 'dictionary' },
              allow: [{ to: { type: 'shared-type' } }, { to: { type: 'dictionary' } }],
            },
            { from: { type: 'shared-type' }, allow: [{ to: { type: 'dictionary' } }] },
            // Page — colocated components, shared UI, dictionaries, api-helpers, auth, providers
            {
              from: { type: 'page' },
              allow: [
                { to: { type: 'page-component' } },
                { to: { type: 'page-provider' } },
                { to: { type: 'shared-ui' } },
                { to: { type: 'dictionary' } },
                { to: { type: 'shared-type' } },
                { to: { type: 'api-helper' } },
                { to: { type: 'auth' } },
                { to: { type: 'page' } },
              ],
            },
          ],
        },
      ],
    },
  },

  // Global ignores
  globalIgnores(['.next/**', 'out/**', 'build/**', 'coverage/**', 'next-env.d.ts']),
]);

export default eslintConfig;
