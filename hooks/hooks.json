{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-old-versions.sh\"",
            "description": "Remove stale jkit cache versions, keep only the active one"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforce-commit-skill.sh\"",
            "description": "Detect commit intent and force jkit:commit skill invocation"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-commands.sh\"",
            "description": "Block dangerous commands (rm , db, chmod)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive-git.sh\"",
            "description": "Block destructive git commands (stash, reset --hard, clean -f, push --force, rebase, commit --amend 등)"
          }
        ]
      }
    ]
  }
}
