{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "declaration": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strictNullChecks": true
  },
  "includeAdd": [],
  "extraFiles": {}
}
